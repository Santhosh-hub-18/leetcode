import java.util.*;
class Solution{
    public void reverseString(char[] s){
        char[] arr=new char[s.length];
        int a=0;
        for(int i=s.length-1;i>=0;i--){
            arr[a]=s[i];
            a++;
        }
        for(int i=0;i<s.length;i++)
        {
            s[i]=arr[i];
        }
    }
}
