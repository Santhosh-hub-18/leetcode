class Solution {
    public int[] getConcatenation(int[] nums) {
        int ans[]=new int[nums.length*2];
        int j=0;
        for(int i=0;i<nums.length;i++)
        {
            ans[i]=nums[i];    
        }
        for(int k=nums.length;k<ans.length;k++){
            ans[k]=nums[k-nums.length];
            j++;
        }
        return ans;
    }
}
